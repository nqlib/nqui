{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "noEmit": false
  },
  "include": ["src/index.ts", "src/entries/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "dist-app",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
